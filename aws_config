Crear el S3 bucket para Terraform state: curso-cicd-tfstate-jdgut-753159
aws --profile curso_cicd s3api create-bucket `
  --bucket curso-cicd-tfstate-jdgut-753159 `
  --region us-east-1

aws --profile curso_cicd s3api put-bucket-versioning `
  --bucket curso-cicd-tfstate-jdgut-753159 `
  --versioning-configuration Status=Enabled
  
aws --profile curso_cicd s3api put-bucket-encryption `
  --bucket curso-cicd-tfstate-jdgut-753159 `
  --server-side-encryption-configuration '{ 
    "Rules": [{
      "ApplyServerSideEncryptionByDefault": {
        "SSEAlgorithm": "AES256"
      }
    }]
  }'

aws --profile curso_cicd s3api put-public-access-block `
  --bucket curso-cicd-tfstate-jdgut-753159 `
  --public-access-block-configuration '{
    "BlockPublicAcls": true,
    "IgnorePublicAcls": true,
    "BlockPublicPolicy": true,
    "RestrictPublicBuckets": true
  }'

aws --profile curso_cicd dynamodb create-table `
  --table-name terraform-state-locks `
  --attribute-definitions AttributeName=LockID,AttributeType=S `
  --key-schema AttributeName=LockID,KeyType=HASH `
  --billing-mode PAY_PER_REQUEST `
  --region us-east-1


$Env:AWS_PROFILE = "curso_cicd"
$Env:AWS_DEFAULT_REGION = "us-east-1"

terraform -chdir=infra init `
  -backend-config="profile=curso_cicd" `
  -backend-config="bucket=curso-cicd-tfstate-jdgut-753159" `
  -backend-config="key=backend/staging/terraform.tfstate" `
  -backend-config="region=us-east-1" `
  -backend-config="dynamodb_table=terraform-state-locks"

terraform -chdir=infra workspace show

terraform -chdir=infra plan `
    -var-file="staging.tfvars" `
    -out="staging.tfplan"

terraform -chdir=infra apply `
    "staging.tfplan"


terraform -chdir=infra destroy `
    -var-file="staging.tfvars" `
    -out="staging.tfplan"

